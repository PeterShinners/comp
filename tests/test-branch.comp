!no-default
!import branch comp "branch"

!func if.test-condition-true ~nil (
    3 | if :($ > 2) :("yes") | is "yes"
)
!func if.test-condition-false ~nil (
    3 | if :($ > 5) :("yes") | is 3
)


!func else.test-runs-when-no-branch-hit ~nil (
    3
    | if :($ > 5) :("if")
    | elif :($ > 4) :("elif")
    | else :("else")
    | is "else"
)
!func else.test-skips-when-branch-hit ~nil (
    3
    | if :($ > 2) :("if")
    | else :("else")
    | is "if"
)

!func match.test-case-hit ~nil (
    "b"
    | match
    | case "a" :("A")
    | case "b" :("B")
    | default :("Z")
    | is "B"
)
!func match.test-default-hit ~nil (
    "x"
    | match
    | case "a" :("A")
    | case "b" :("B")
    | default :("Z")
    | is "Z"
)

!func case.test-computed-when ~nil (
    4
    | match
    | case :($ - 1) :("three")
    | case :($) :("four")
    | default :("other")
    | is "four"
)
!func case.test-first-match-wins ~nil (
    2
    | match
    | case 2 :("first")
    | case 2 :("second")
    | default :("other")
    | is "first"
)

!func default.test-pass-through-when-matched ~nil (
    "k"
    | match
    | case "k" :("hit")
    | default :("miss")
    | is "hit"
)
!func default.test-executes-when-not-matched ~nil (
    "k"
    | match
    | case "z" :("hit")
    | default :("miss")
    | is "miss"
)

!func try.test-invokes-callable ~nil (
    3 | try :($ + 2) | is 5
)
!func try.test-falls-back-to-value ~nil (
    3 | try "plain" | is "plain"
)

!func pick.test-then-branch ~nil (
    5 | pick :($ > 2) :("high") :("low") | is "high"
)
!func pick.test-else-branch ~nil (
    1 | pick :($ > 2) :("high") :("low") | is "low"
)


!func is ~any|nil (
    !param value ~any|nil = false
    !on ($ == value) ~false !fail "Result %($) is not %(value)"
    $
)


!func some.test-match-found ~nil (
    {1 2 3} | some :($ > 2) | is true
)
!func some.test-no-match ~nil (
    {1 2 3} | some :($ > 10) | is false
)


!func every.test-all-pass ~nil (
    {2 4 6} | every :($ > 0) | is true
)
!func every.test-one-fails ~nil (
    {2 -3 6} | every :($ > 0) | is false
)


!func fallback-operator.test-field-access ~nil (
    !my data = {x=1}
    (data.missing-field ?? "default") | is "default"
)
!func fallback-operator.test-nested-in-statement ~nil (
    !my data = {y=2}
    (data.missing ?? 99) | is 99
)


!func scope.test-recursive-function-locals-isolated ~nil (
    6 | countdown-check | is 0
)

!func scope.test-nested-block-shares-function-locals ~nil (
    !my total = 0
    !my done = ({1 2 3} | every :(
        !my total = (total + $)
        true
    ))
    total | is 6
)

!func countdown-check ~num (
    !my n = $
    !on n == 0
    ~true 0
    ~false (
        !my original = n
        !my child = ((n - 1) | countdown-check)
        !on original == n
        ~true child
        ~false !fail @fmt"recursive local changed from %(original) to %(n)"
    )
)

