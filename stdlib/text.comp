/// Text operations
/// Functions for manipulating and analyzing text strings.

!import py comp "py"
!import limit comp "limit"
!import num comp "num"
!import unit comp "unit"


!tag trim-mode {whitespace chars}
!tag target {both start end}
!tag case {sensitive insensitive}


/// Predefined text types
!shape letter ~text<size=1>
!shape text-empty ~text<size=0> = ""  // is this actually useful?


/// Get text length in characters
!pure length ~text (
    $ | py.pure-call :"len"
)

/// Test if text is empty
!pure is-empty ~text (
    !not ($ | py.pure-call :"bool")
)

/// Transform text to uppercase
!pure uppercase ~text @preserve-unit (
    $ | py.pure-call :"str.upper"
)

/// Transform text to lowercase
!pure lowercase ~text @preserve-unit (
    $ | py.pure-call :"str.lower"
)

/// Remove whitespace from text ends
!pure trim ~text @preserve-unit (
    :param what~trim-mode=trim-mode.whitespace
    :param target~target=target.both
    !on target
    ~start ($ | py.pure-call :"str.lstrip")
    ~end ($ | py.pure-call :"str.rstrip")
    ~both ($ | py.pure-call :"str.strip")
)

/// Test if text contains only whitespace or is empty
!pure is-blank ~text (
    $ | trim | is-empty
)

/// Test if text contains only numeric characters
!pure is-numeric ~text (
    $ | py.pure-call :"str.isnumeric"
)

/// Test if text contains only alphabetic characters
!pure is-alpha ~text (
    $ | py.pure-call :"str.isalpha"
)

/// Test if text contains only alphanumeric characters
!pure is-alphanumeric ~text (
    $ | py.pure-call :"str.isalnum"
)

/// Test if text contains only lowercase characters
!pure is-lowercase ~text (
    $ | py.pure-call :"str.islower"
)

/// Test if text contains only uppercase characters
!pure is-uppercase ~text (
    $ | py.pure-call :"str.isupper"
)

/// Test if text contains a substring
!pure contains ~text (
    :param substring~text<non-empty>
    :param case~case=case.sensitive
    !let text (
        !on case
        ~insensitive ($ | lowercase)
        ~sensitive $
    )
    !let key (
        !on case
        ~insensitive (substring | lowercase)
        ~sensitive substring
    )
    {text key} | py.pure-call :"str.__contains__"
)

/// Test if text starts with a prefix
!pure starts-with ~text (
    :param prefix~text<non-empty>
    {$ prefix} | py.pure-call :"str.startswith"
)

/// Test if text ends with a suffix
!pure ends-with ~text (
    :param suffix~text<non-empty>
    {$ suffix} | py.pure-call :"str.endswith"
)

/// Find first occurrence of substring, return index or nil
!pure find ~text (
    :param substring~text<non-empty>
    !let result ({$ substring} | py.pure-call :"str.find")
    !on (result == -1)
    ~true nil
    ~false result
)

/// Count occurrences of substring
!pure count ~text (
    :param substring~text<non-empty>
    {$ substring} | py.pure-call :"str.count"
)

/// Replace all occurrences of old with new
!pure replace ~text @preserve-unit (
    :param old~text<non-empty>
    :param new~text
    {$ old new} | py.pure-call :"str.replace"
)

/// Split text by separator
!pure split ~text (
    :param separator~text<non-empty>=" "
    {$ separator} | py.pure-call :"str.split"
)

/// Split text into lines
!pure lines ~text (
    $ | py.pure-call :"str.splitlines"
)

/// Join a positional collection of strings with a separator
/// Input must be a positional struct of strings: {"Apple" "Banana" "Cherry"}
!pure join ~text* (
    :param separator~text = ""
    {separator $} | py.pure-call :"str.join"
)

/// Repeat text n times
!pure repeat ~text @preserve-unit (
    :param times~index
    {$ times} | py.pure-call :"operator.mul"
)

/// Pad text on left
!pure pad-left ~text @preserve-unit (
    :param width~index
    :param fill~letter=" "
    {$ width fill} | py.pure-call :"str.rjust"
)

/// Pad text on right
!pure pad-right ~text @preserve-unit (
    :param width~index
    :param fill~letter=" "
    {$ width fill} | py.pure-call :"str.ljust"
)

/// Center text within width
!pure center ~text @preserve-unit (
    :param width~index
    :param fill~letter=" "
    {$ width fill} | py.pure-call :"str.center"
)

/// Capitalize first character
!pure capitalize ~text @preserve-unit (
    $ | py.pure-call :"str.capitalize"
)

/// Convert to title case
!pure title ~text @preserve-unit (
    $ | py.pure-call :"str.title"
)

/// Parse text as a number — fails if the text is not a valid numeric literal
!pure to-num ~text (
    $ | py.pure-call :"decimal.Decimal"
)
