/// Get the assembled authority string (user:pass@host:port).
///
/// Returns nil if host is nil.
///
/// Examples:
///   (u | uri.authority)   // => "user:pass@host.com:8080"
!pure authority ~uri (
    !on $.host ~text (
        !my credentials = ($.user | non-nil-joins ":" $.password)
        ($.host
        | non-nil-joins ":" $.port
        | if (credentials != nil) :(
            credentials | non-nil-joins "@" $
        ))
    )
)


// ---------------------------------------------------------------------------
// Anchor
// ---------------------------------------------------------------------------

/// Anchor a URI against a base, similar to os.path.join.
///
/// If the second URI has an absolute path (or a protocol), the first URI
/// is ignored entirely. Otherwise the second URI's path is appended to
/// the first, and the second URI's filename fields take precedence.
///
/// Non-path fields (protocol, authority, query, fragment) from the second
/// URI override the first when they are non-nil.
///
/// Examples:
///   (base | uri.anchor relative)
///   (base | uri.anchor absolute)   // base is discarded
!pure anchor ~uri (
    !param base ~uri
    // TODO
    nil
)


// ---------------------------------------------------------------------------
// URL encoding
// ---------------------------------------------------------------------------

/// Percent-encode a text string for use in a URI.
///
/// Encodes spaces and special characters. Forward slashes are preserved.
///
/// Examples:
///   "hello world/path" | uri.encode   // => "hello%20world/path"
!pure encode ~text (
    $ | py.pure-call "urllib.parse.quote"
)

/// Decode a percent-encoded URI string back to text.
///
/// Examples:
///   "hello%20world" | uri.decode   // => "hello world"
!pure decode ~text (
    $ | py.pure-call "urllib.parse.unquote"
)


// ---------------------------------------------------------------------------
// Query string helpers
// ---------------------------------------------------------------------------

/// Parse a query string into a struct of key=value pairs.
///
/// Duplicate keys produce the last value (not a list).
///
/// Examples:
///   "a=1&b=hello&c=3" | uri.query-unpack   // => {a="1" b="hello" c="3"}
!pure query-unpack ~text (
    // TODO
    nil
)

/// Assemble a struct of key=value pairs into a query string.
///
/// Examples:
///   {a="1" b="hello"} | uri.query-pack   // => "a=1&b=hello"
!pure query-pack ~struct (
    // TODO
    nil
)



/// Append non nil tokens (up to two) to a string
!pure non-nil-joins& ~(text|nil) (
    !param token1 ~(text|nil)
    !param token2 ~(text|nil) = ""
    !on $
    ~text ($
    | if (token1 != nil !and token2 != nil) :(
        ({$ token1 token2} | join)
    ))
)

/// Append suffix to text if it doesn't already end with it
!pure ensure-suffix& ~text (
    !param suffix ~text
    $ | if !not ($ | text.ends-with suffix) :(
        ({$ suffix} | join)
    )
)
