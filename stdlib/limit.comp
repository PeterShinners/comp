/// Standard limits for types.
/// These are pure functions used as validation constraints during shape morphing.
/// Each limit either raises a failure or passes without returning a meaningful value.

!import py comp "py"
!import num comp "num"
!import text comp "text"
!import struct comp "struct"


/// Inclusive minimum bound: value must be >= amount
!pure ge ~num (
    !param amount ~num
    !on $ < amount
    ~true !fail.value "Value is below minimum"
    ~false true
)

/// Inclusive maximum bound: value must be <= amount
!pure le ~num (
    !param amount ~num
    !on $ > amount
    ~true !fail.value "Value is above maximum"
    ~false true
)

/// Exclusive lower bound: value must be > amount
!pure gt ~num (
    !param amount ~num
    !on $ <= amount
    ~true !fail.value "Value must be above bound"
    ~false true
)

/// Exclusive upper bound: value must be < amount
!pure lt ~num (
    !param amount ~num
    !on $ >= amount
    ~true !fail.value "Value must be below bound"
    ~false true
)

/// Equality constraint: value must equal amount exactly
!pure eq ~num (
    !param amount ~num
    !on $ == amount
    ~false !fail.value "Value must equal the required amount"
    ~true true
)

