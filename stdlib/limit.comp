    !on in-set
    ~true !fail.value "Value must not be any of the excluded values"
    ~false true
)
*/

/// Integer constraint: value must have no fractional part
!pure integer ~num (
    !my parts [{$ 1} | py.pure-call "divmod"]
    !on (parts.#1 == 0)
    ~true true
    ~false !fail.value "Value must be an integer"
)

/// ASCII constraint: text must contain only ASCII characters (codepoints 0-127)
!pure ascii ~text (
    !on [{$ "isascii"} | py.pure-call "str.isascii"]
    ~false !fail.value "Text contains non-ASCII characters"
    ~true true
)

/// Non-empty constraint: text must have at least one character
!pure non-empty ~text (
    !on [$ | length] == 0
    ~true !fail.value "Text must not be empty"
    ~false true
)

/// Single-character constraint: text must be exactly one character
!pure single-char ~text (
    !on [$ | length] == 1
    ~true true
    ~false !fail.value "Text must be exactly one character"
)

/// Size constraint: text length must be exact or within a range.
/// Pass an exact count: size=3
/// Pass a min/max range struct: size={1 32}
!pure size ~text (
    !param range ~({~index ~index} | index)
    !my n [$ | length]
    !on range
    ~num (
        !on (n == range)
        ~true true
        ~false !fail.value "Text must be exactly this length"
    )
    ~struct (
        !on (n < range.#0)
        ~true !fail.value "Text is too short"
        ~false (
            !on (n > range.#1)
            ~true !fail.value "Text is too long"
            ~false true
        )
    )
)

