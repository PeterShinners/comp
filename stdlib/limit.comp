/// Pattern match constraint: text must match the given regex pattern
!pure match ~text (
    !param pattern ~text
    !my result [{pattern $} | py.pure-call "re.fullmatch"]
    !on (result == nil)
    ~true !fail.value "Text does not match pattern"
    ~false true
)
