/// Entry point: run all early-phase validators on a raw COP tree.
///
/// Call this before name resolution. Checks are purely structural.
///
/// Args:
///   min-severity: (callout) Minimum severity to report (default: warning)
///
/// Returns: struct of all collected callouts
!pure validate-early (
    !param min-severity ~callout = callout.warning
    !my args {min-severity=min-severity}
    {}
)


// ===== Resolved validators =====
// Run after name resolution. Can inspect purity flags, qualified names,
// and signature shapes, but folding has not yet occurred.


/// Check that pure functions do not call impure functions.
///
/// Walks value.block nodes that carry a signature.pure marker. Inside
/// those bodies, any value.namespace reference to a non-pure callable
/// used as an invocation target is reported.
///
/// Requires a namespace map so purity can be looked up by qualified name.
!pure check-pure-calls-impure (
    !param min-severity ~callout = callout.error
    !param namespace ~any = nil
    !on [min-severity | severity-rank] <= [callout.error | severity-rank]
    ~false {}
    ~true (
        [$ | walk-cop filter="value.block" initial={} :(
            !my node $.node
            !my sig [node | cop-kids | loop.first]
            !my is-pure [sig | cop-fields | ($.pure)] != nil
            !on is-pure
            ~false {callouts={} accum={} recurse=false}
            ~true (
                // Walk the body of this pure block looking for impure calls
                !my body [node | cop-kids | loop.last]
                [body | walk-cop filter="value.invoke" initial={} :(
                    !my callee [$.node | cop-kids | loop.first]
                    !my callee-tag [callee | cop-tag]
                    !on callee-tag == "value.namespace"
                    ~false {callouts={} accum={}}
                    ~true (
                        !my name [callee | cop-fields | ($.name)]
                        !my defn [namespace | (name)]
                        !my is-impure [defn | cop-fields | ($.pure)] == nil
                        !on is-impure
                        ~false {callouts={} accum={}}
                        ~true {callouts={{
                            severity=callout.error
                            code="pure-calls-impure"
                            message=["Pure function calls impure function: " + name]
                            phase=callout.phase.cop
                        }} accum={}}
                    )
                )]
            )
        )]
    )
)


/// Check that each pipeline stage's !depend declarations are satisfied
/// by a preceding stage's !delivers declarations.
///
/// Walks value.pipeline nodes left-to-right, maintaining a set of names
/// delivered so far. Reports any !depend requirement not in that set.
// !pure check-pipeline-dependencies (...)
//   Walks value.pipeline nodes left-to-right, maintaining a set of names
//   delivered so far. Reports any !depend requirement not in that set.
//   (Disabled: !not operator inside loop.filter block needs syntax fix)


