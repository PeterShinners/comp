/// Entry point: run all resolved-phase validators on a name-resolved COP tree.
///
/// Call this after cop_resolve_names. Validators may inspect qualified names
/// and purity flags but should not assume constant folding has occurred.
///
/// Args:
///   min-severity: (callout) Minimum severity to report (default: error)
///   namespace:    (any) Resolved module namespace for purity/shape lookups
///
/// Returns: struct of all collected callouts
!pure validate-resolved (
    !param min-severity ~callout = callout.error
    !param namespace ~any = nil
    !my args {min-severity=min-severity namespace=namespace}
    [$ | check-zero-division args]
)


// ===== Folded validators =====
// Run after constant folding. Constants have been evaluated as far as possible;
// validators here can inspect known-constant values for partial-constant checks
// that folding itself cannot fully evaluate.


/// Check for division or modulo by a constant zero on the right-hand side.
///
/// Catches `x / 0`even when the left side is dynamic, since
/// the failure is guaranteed regardless of the numerator.
!pure check-zero-division (
    !param min-severity ~callout = callout.warning
    !on [min-severity | severity-rank] <= [callout.warning | severity-rank]
    ~false {}
    ~true (
        [$ | walk-cop filter="value.math.binary" initial={} :(
            !my node $.node
            !my op [node | cop-fields | ($.op)]
            !on (op == "/")
            ~false {callouts={} accum={}}
            ~true (
                !my rhs [node | cop-kids | loop.last]
                !my rhs-tag [rhs | cop-tag]
                !on (rhs-tag == "value.number" !or rhs-tag == "value.constant")
                ~false {callouts={} accum={}}
                ~true (
                    !my rhs-val [rhs | cop-fields | ($.value)]
                    !on rhs-val == "0"
                    ~false {callouts={} accum={}}
                    ~true {callouts={{
                        severity=callout.warning
                        code="zero-division"
                        message=["Division or modulo by constant zero will always fail at runtime"]
                        phase=callout.phase.cop
                    }} accum={}}
                )
            )
        )]
    )
)


/// Check for named field access on a constant struct where the field is absent.
///
/// When a value.field node targets a value.constant whose value is a struct,
/// and the requested field name is not present, the access will always fail
/// at runtime. This is detectable after folding because the base is constant.
///
/// Example: {x=1} | (.y)  →  "field 'y' not found on constant struct"
!pure check-constant-undefined-field (
    !param min-severity ~callout = callout.error
    !on [min-severity | severity-rank] <= [callout.error | severity-rank]
    ~false {}
    ~true (
        [$ | walk-cop filter="value.field" initial={} :(
            !my node $.node
            !my base [node | cop-kids | loop.first]
            !my base-tag [base | cop-tag]
            !on base-tag == "value.constant"
            ~false {callouts={} accum={}}
            ~true (
                !my field-name [node | cop-fields | ($.field)]
                !my struct-val [base | cop-fields | ($.value)]
                !my has-field [struct-val | contains-field field-name]
                !on has-field
                ~true {callouts={} accum={}}
                ~false {callouts={{
                    severity=callout.error
                    code="undefined-field"
                    message=["Field '" + field-name + "' not found on constant struct"]
                    phase=callout.phase.cop
                }} accum={}}
            )
        )]
    )
)


// !pure check-constant-wrong-shape (...)
//   Walk value.invoke / value.pipeline where the callee has a known input shape
//   and the piped input is a value.constant. Attempt morph; report mismatch.

// !pure check-constant-out-of-bounds (...)
//   Walk value.field nodes using positional access (#N) where the base is a
//   value.constant struct. Report when N >= struct field count.

// !pure check-logic-known-non-bool (...)
//   Walk value.logic.binary nodes where one side is a value.constant not of
//   bool type. Report the non-boolean operand.

// !pure check-math-known-non-number (...)
//   Walk value.math.binary nodes where one side is a value.constant not of
//   num type. Report the non-numeric operand.

// !pure check-unreachable-on-branches (...)
//   Walk op.on nodes where the condition is value.constant. Report branches
//   whose pattern cannot match the known constant value.

// !pure check-shape-invoke-constant-fail (...)
//   Walk value.invoke where callee resolves to a shape and piped input is
//   value.constant. Attempt morph at compile time; report guaranteed failure.

// !pure check-sql-template-unit (...)
//   Walk string template expressions passed to functions expecting a text unit.
//   Report when a template contains unguarded dynamic values (injection risk).


/// Check for op.fail nodes in a constant-folded COP tree.
///
/// The folder converts guaranteed-failure expressions (e.g. pure evaluation problems,
/// type mismatches) into op.fail nodes rather than aborting compilation.
/// Any op.fail reachable at runtime will always fail, so we surface these
/// here as errors after folding is complete.
///
/// This catches both fold-synthesised failures and user-written !fail
/// expressions that appear in always-reachable positions.
!pure check-constant-fail (
    !param min-severity ~callout = callout.warning
    !on [min-severity | severity-rank] <= [callout.warning | severity-rank]
    ~false {}
    ~true (
        [$ | walk-cop filter="op.fail" initial={} :(
            !my node $.node
            !my inner [node | cop-kids | loop.first | cop-fields | ($.value)]
            !my reason [inner | ($.fail)]
            {callouts={{
                severity=callout.error
                code="constant-fail"
                message=[@fmt"Expression always fails at runtime: %(reason)"]
                phase=callout.phase.cop
            }} accum={}}
        )]
    )
)


/// Entry point: run all folded-phase validators on a constant-folded COP tree.
///
/// Call this after coptimize with fold=True. Folding has already evaluated
/// all fully-constant subexpressions; validators here cover partial-constant
/// cases that remain after folding.
///
/// Args:
///   min-severity: (callout) Minimum severity to report (default: warning)
///   namespace:    (any) Resolved module namespace for shape lookups
///
/// Returns: struct of all collected callouts
!pure validate-folded (
    !param min-severity ~callout = callout.warning
    !param namespace ~any = nil
    !my args {min-severity=min-severity namespace=namespace}
    [$ | check-constant-fail args]
)
