/// Callout: validation result definitions for the comp analysis pipeline.
///
/// A callout is any finding emitted during analysis — from a hard parse error
/// to a style hint. Severity levels, source spans, and the callout shape are
/// defined here so that validators written in comp can produce and inspect
/// callouts using the standard morph/pattern machinery.
///
/// Severity levels (low ordinal = high severity):
///   callout.error   — code cannot run correctly
///   callout.warning — legal but probably wrong
///   callout.info    — notable but intentional
///   callout.hint    — style / idiomatic, low signal
///
/// Pipeline phases (in order):
///   callout.phase.parse    — lark grammar / token errors
///   callout.phase.cop      — raw cop node construction
///   callout.phase.resolve  — name resolution
///   callout.phase.codegen  — instruction generation


!import n comp "num"
!import loop comp "loop"

// ===== Severity =====

/// Severity level tags for callouts
!tag callout { error warning info hint }


// ===== Pipeline phases =====

/// Pipeline phase tags — which build stage produced a callout.
/// cop covers raw construction, name resolution, and constant folding.
!tag callout.phase { parse cop codegen }


// ===== Source location shapes =====

/// A source position: file path, 1-based line and column, character length.
/// length=0 indicates a point location with no extent.
!shape span ~{
    file~text
    line~n.index
    col~n.index
    length~n.index
}

/// An attached enrichment on a callout — no severity or code of its own.
/// Notes are leaves: they cannot contain further notes.
/// Used for suggestions and secondary context: "did you mean X?", "declared here".
!shape note ~{
    message~text
    location~(location | nil)
}

/// A span with an optional label contextualising it.
/// Used for the primary location and each related location in a callout,
/// e.g. label="first defined here" or label="redefined here".
!shape location ~{
    span~span
    label~text
}


// ===== Callout shape =====

/// A single validation finding from any pipeline phase.
///
/// related holds secondary labeled locations — useful for "conflicting
/// definition" callouts that need to point at two source sites.
///
/// notes holds attached child callouts (typically info or hint severity)
/// that enrich the primary finding without being standalone findings.
/// Examples: "did you mean X?", "declared here".
!shape callout ~{
    severity~callout
    code~text
    message~text
    phase~(callout.phase | nil)
    primary~(location | nil)
    related~location*
    notes~note*
}


// ===== Severity ordering =====

/// Severity ordering: error=0, warning=1, info=2, hint=3 (lower = more severe).
/// Used by validate-cop to skip validators that can't produce
/// callouts at the requested minimum severity level.
!pure severity-rank ~callout (
    !on $
    ~callout.error   0
    ~callout.warning 1
    ~callout.info    2
    ~callout.hint    3
    ~any 4  // shouldn't happen but always happens
)


// ===== COP tree walking =====

/// Walk a COP tree depth-first, calling a block on each node.
///
/// walk-cop is a builtin that handles the recursion and calls your block
/// on each matching node. The block receives piped ($) a struct:
///   $.node   — the current COP node
///   $.depth  — tree depth (0 for root)
///   $.accum  — accumulated value from parent's result
///
/// The block should return a struct with:
///   $.callouts — struct of callouts to collect ({} for none)
///   $.accum    — value to pass to child traversals
///   $.recurse  — false to skip children (default true)
///
/// Returning ~skip also skips recursion into children.
/// A non-struct return is treated as a single callout to collect.
///
/// Args (to walk-cop builtin):
///   filter:  (text) COP tag to filter for ("" means all nodes)
///   initial: (any) Initial accumulator value
///   op:      (block) Called on each matching node
///
/// Returns: struct of all collected callouts
///
/// Examples:
///   cop-root | walk-cop filter="value.constant" :(
///       {callouts={} accum=nil}
///   )


// ===== Early validators =====
// Run on raw COP before name resolution. Structural and scope-local checks only.


/// Check for duplicate field names within a single struct literal.
///
/// Finds struct.define nodes where two or more struct.namefield children
/// share the same name. Reports the second (and later) occurrences.
///
/// Example: {x=1 x=2}  →  "duplicate field 'x' in struct literal"
!pure check-duplicate-struct-fields (
    !param min-severity ~callout = callout.warning
    !on [min-severity | severity-rank] <= [callout.warning | severity-rank]
    ~false {}
    ~true (
        [$ | walk-cop filter="struct.define" initial={} :(
            !my node $.node
            !my fields [node | cop-kids | (loop.filter :([$ | cop-tag] == "struct.namefield"))]
            !my names [fields | loop.map :([$ | cop-fields | ($.name)])]
            !my dupes [names | loop.find-duplicates]
            !on dupes == {}
            ~true {callouts={} accum={}}
            ~false {callouts={{
                severity=callout.warning
                code="duplicate-struct-field"
                message=["Duplicate field name in struct literal: " + [dupes | loop.first]]
                phase=callout.phase.cop
            }} accum={}}
        )]
    )
)


/// Check for duplicate pattern branches in a single !on dispatch.
///
/// Finds op.on nodes where two or more op.on.branch children match the
/// same shape or tag. Only checks literal pattern arms — computed patterns
/// are skipped. Reports the second (and later) occurrences.
///
/// Example: !on x  ~true ...  ~true ...  →  "duplicate branch ~true in !on"
!pure check-duplicate-on-branches (
    !param min-severity ~callout = callout.warning
    !on [min-severity | severity-rank] <= [callout.warning | severity-rank]
    ~false {}
    ~true (
        [$ | walk-cop filter="op.on" initial={} :(
            !my node $.node
            !my branches [node | cop-kids | (loop.filter :([$ | cop-tag] == "op.on.branch"))]
            !my patterns [branches | loop.map :([$ | cop-kids | loop.first | cop-tag])]
            !my dupes [patterns | loop.find-duplicates]
            !on dupes == {}
            ~true {callouts={} accum={}}
            ~false {callouts={{
                severity=callout.warning
                code="duplicate-on-branch"
                message=["Duplicate branch pattern in !on: " + [dupes | loop.first]]
                phase=callout.phase.cop
            }} accum={}}
        )]
    )
)


