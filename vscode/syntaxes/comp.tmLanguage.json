{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Comp",
  "scopeName": "source.comp",
  "patterns": [
    { "include": "#comments" },
    { "include": "#module-declarations" },
    { "include": "#block-operators" },
    { "include": "#wrappers" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#input-references" },
    { "include": "#shape-annotations" },
    { "include": "#capture-expr" },
    { "include": "#stash-access" },
    { "include": "#unit-cast" },
    { "include": "#operators" },
    { "include": "#type-names" },
    { "include": "#function-calls" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.comp",
          "begin": "/\\*\\*(?!/)",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.comp" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.comp" } },
          "patterns": [{ "include": "#comments" }]
        },
        {
          "name": "comment.block.comp",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.comp" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.comp" } },
          "patterns": [{ "include": "#comments" }]
        },
        {
          "name": "comment.line.documentation.comp",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.comp",
          "match": "//.*$"
        }
      ]
    },

    "module-declarations": {
      "patterns": [
        {
          "comment": "!import alias comp \"source\" — module import",
          "match": "(!import)\\s+([a-zA-Z_][\\w-]*)(?:\\s+(comp))?",
          "captures": {
            "1": { "name": "keyword.control.import.comp" },
            "2": { "name": "entity.name.namespace.comp" },
            "3": { "name": "keyword.control.import.comp" }
          }
        },
        {
          "comment": "!func/!pure name ~type — function declaration",
          "match": "(!(func|pure))\\s+([a-zA-Z_][\\w-]*&?)(?:\\s+(~[a-zA-Z_][\\w.|-]*))?",
          "captures": {
            "1": { "name": "keyword.declaration.function.comp" },
            "3": { "name": "entity.name.function.comp" },
            "4": { "name": "storage.type.comp" }
          }
        },
        {
          "comment": "!startup name — entry point",
          "match": "(!startup)\\s+([a-zA-Z_][\\w-]*)",
          "captures": {
            "1": { "name": "keyword.declaration.function.comp" },
            "2": { "name": "entity.name.function.comp" }
          }
        },
        {
          "comment": "!shape name — shape/type declaration",
          "match": "(!shape)\\s+([a-zA-Z_][\\w-]*&?)",
          "captures": {
            "1": { "name": "keyword.declaration.type.comp" },
            "2": { "name": "entity.name.type.comp" }
          }
        },
        {
          "comment": "!tag name — tag declaration",
          "match": "(!tag)\\s+([a-zA-Z_][\\w.-]*&?)",
          "captures": {
            "1": { "name": "keyword.declaration.type.comp" },
            "2": { "name": "entity.name.type.comp" }
          }
        },
        {
          "comment": "!context name — module context declaration",
          "match": "(!context)\\s+([a-zA-Z_][\\w-]*)",
          "captures": {
            "1": { "name": "keyword.declaration.module.comp" },
            "2": { "name": "entity.name.namespace.comp" }
          }
        },
        {
          "comment": "!alias/!export name — namespace re-export",
          "match": "(!alias|!export)\\s+([a-zA-Z_][\\w-]*&?)",
          "captures": {
            "1": { "name": "keyword.declaration.module.comp" },
            "2": { "name": "entity.name.namespace.comp" }
          }
        },
        {
          "comment": "!mod name — module configuration value",
          "match": "(!mod)\\s+([a-zA-Z_][\\w.-]*)",
          "captures": {
            "1": { "name": "keyword.declaration.module.comp" },
            "2": { "name": "entity.name.namespace.comp" }
          }
        },
        {
          "comment": "!package name — package metadata key",
          "match": "(!package)\\s+([a-zA-Z_][\\w-]*)",
          "captures": {
            "1": { "name": "keyword.declaration.module.comp" },
            "2": { "name": "variable.other.member.comp" }
          }
        }
      ]
    },

    "block-operators": {
      "patterns": [
        {
          "comment": "!param name — parameter declaration inside function body",
          "match": "(!param)\\s+([a-zA-Z_][\\w-]*)",
          "captures": {
            "1": { "name": "keyword.other.param.comp" },
            "2": { "name": "variable.parameter.comp" }
          }
        },
        {
          "comment": "!my name — local variable binding",
          "match": "(!my)\\s+([a-zA-Z_][\\w-]*)",
          "captures": {
            "1": { "name": "keyword.control.binding.comp" },
            "2": { "name": "variable.other.local.comp" }
          }
        },
        {
          "comment": "!ctx name — context variable binding",
          "match": "(!ctx)\\s+([a-zA-Z_][\\w-]*)",
          "captures": {
            "1": { "name": "keyword.control.binding.comp" },
            "2": { "name": "variable.other.local.comp" }
          }
        },
        {
          "comment": "!stash var&key.path = value — stash write",
          "match": "(!stash)\\s+([a-zA-Z_][\\w-]*)",
          "captures": {
            "1": { "name": "keyword.other.stash.comp" },
            "2": { "name": "variable.other.local.comp" }
          }
        },
        {
          "comment": "!on — pattern dispatch operator",
          "name": "keyword.control.dispatch.comp",
          "match": "!on\\b"
        },
        {
          "comment": "!transact — transaction scope",
          "name": "keyword.control.transact.comp",
          "match": "!transact\\b"
        },
        {
          "comment": "!defer — deferred evaluation",
          "name": "keyword.control.defer.comp",
          "match": "!defer\\b"
        },
        {
          "comment": "!forward — redispatch to next overload",
          "name": "keyword.control.forward.comp",
          "match": "!forward\\b"
        },
        {
          "comment": "!fail — raise a failure value",
          "name": "keyword.control.fail.comp",
          "match": "!fail\\b"
        },
        {
          "comment": "!grab/!drop/!pull/!push — handle operators",
          "name": "keyword.other.handle.comp",
          "match": "!(grab|drop|pull|push)\\b"
        },
        {
          "comment": "!and/!or/!not — logical operators",
          "name": "keyword.operator.logical.comp",
          "match": "!(and|or|not)\\b"
        },
        {
          "comment": "catch-all for any remaining !operator",
          "name": "keyword.other.bang.comp",
          "match": "![a-zA-Z][a-zA-Z0-9-]*\\b"
        }
      ]
    },

    "wrappers": {
      "patterns": [
        {
          "comment": "@wrapper — behavior annotation on functions/expressions",
          "match": "(@)([a-zA-Z_][\\w-]*)",
          "captures": {
            "1": { "name": "punctuation.definition.decorator.comp" },
            "2": { "name": "entity.name.function.decorator.comp" }
          }
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "comment": "Triple-quoted multiline string",
          "name": "string.quoted.double.multiline.comp",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.comp" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.comp" } },
          "patterns": [
            { "include": "#string-interpolation" },
            { "name": "constant.character.escape.comp", "match": "\\\\[\\\\\"nrt0]" }
          ]
        },
        {
          "name": "string.quoted.double.comp",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.comp" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.comp" } },
          "patterns": [
            { "include": "#string-interpolation" },
            { "name": "constant.character.escape.comp", "match": "\\\\[\\\\\"nrt0]" }
          ]
        }
      ]
    },

    "string-interpolation": {
      "patterns": [
        {
          "comment": "Escaped %% — literal percent",
          "name": "constant.character.escape.comp",
          "match": "%%"
        },
        {
          "comment": "Interpolation %(expr)[format]",
          "name": "meta.interpolation.comp",
          "begin": "%\\(",
          "end": "\\)(\\[[^\\]]*\\])?",
          "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.comp" } },
          "endCaptures": {
            "0": { "name": "punctuation.section.interpolation.end.comp" },
            "1": { "name": "constant.other.format-spec.comp" }
          },
          "contentName": "source.comp.embedded",
          "patterns": [
            { "include": "#comments" },
            { "include": "#input-references" },
            { "include": "#stash-access" },
            { "include": "#unit-cast" },
            { "include": "#operators" },
            { "include": "#numbers" },
            { "include": "#constants" },
            { "include": "#function-calls" }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "comment": "Fractional number n/d (rational literal)",
          "name": "constant.numeric.rational.comp",
          "match": "\\b[0-9][0-9_]*/[0-9][0-9_]*\\b"
        },
        {
          "comment": "Hex literal 0x...",
          "name": "constant.numeric.hex.comp",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "comment": "Binary literal 0b...",
          "name": "constant.numeric.binary.comp",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "comment": "Octal literal 0o...",
          "name": "constant.numeric.octal.comp",
          "match": "\\b0[oO][0-7_]+\\b"
        },
        {
          "comment": "Decimal or integer literal",
          "name": "constant.numeric.comp",
          "match": "\\b[0-9][0-9_]*(\\.[0-9_]*)?([eE][+-]?[0-9_]+)?\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "comment": "nil — absence of a value",
          "name": "constant.language.nil.comp",
          "match": "\\bnil\\b"
        },
        {
          "comment": "true/false — boolean literals",
          "name": "constant.language.boolean.comp",
          "match": "\\b(true|false)\\b"
        }
      ]
    },

    "input-references": {
      "patterns": [
        {
          "comment": "$$$ — outermost scope pipeline input",
          "name": "variable.language.input.comp",
          "match": "\\$\\$\\$"
        },
        {
          "comment": "$$ — outer scope pipeline input",
          "name": "variable.language.input.comp",
          "match": "\\$\\$"
        },
        {
          "comment": "$ — current pipeline input",
          "name": "variable.language.input.comp",
          "match": "\\$"
        }
      ]
    },

    "shape-annotations": {
      "patterns": [
        {
          "comment": "~type — input shape / type annotation",
          "match": "(~)([a-zA-Z_][\\w.-]*(?:\\|[a-zA-Z_][\\w.-]*)?)?",
          "captures": {
            "1": { "name": "keyword.operator.shape.comp" },
            "2": { "name": "storage.type.comp" }
          }
        }
      ]
    },

    "capture-expr": {
      "patterns": [
        {
          "comment": ": before (, {, [ — capture/defer a block, struct, or pipeline",
          "match": "(:)(?=[\\(\\{\\[])",
          "captures": {
            "1": { "name": "keyword.operator.capture.comp" }
          }
        }
      ]
    },

    "stash-access": {
      "patterns": [
        {
          "comment": "&key or &key.path — module-private stash read",
          "match": "(&)([a-zA-Z_][\\w-]*(?:\\.[a-zA-Z_][\\w-]*)*)",
          "captures": {
            "1": { "name": "punctuation.definition.stash.comp" },
            "2": { "name": "variable.other.stash.comp" }
          }
        }
      ]
    },

    "unit-cast": {
      "patterns": [
        {
          "comment": "#unit — unit cast or unit constraint in shapes",
          "match": "(#)([a-zA-Z_][\\w-]*)",
          "captures": {
            "1": { "name": "punctuation.definition.unit.comp" },
            "2": { "name": "entity.name.tag.unit.comp" }
          }
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "comment": "Pipeline fallback operator |?",
          "name": "keyword.operator.pipeline-fallback.comp",
          "match": "\\|\\?"
        },
        {
          "comment": "Pipeline operator |",
          "name": "keyword.operator.pipeline.comp",
          "match": "\\|(?!\\?)"
        },
        {
          "comment": "Value fallback operator ??",
          "name": "keyword.operator.fallback.comp",
          "match": "\\?\\?"
        },
        {
          "comment": "Three-way comparison <>",
          "name": "keyword.operator.comparison.comp",
          "match": "<>"
        },
        {
          "comment": "Equality operators == !=",
          "name": "keyword.operator.comparison.comp",
          "match": "==|!="
        },
        {
          "comment": "Ordering operators <= >= < >",
          "name": "keyword.operator.comparison.comp",
          "match": "<=|>=|<(?!>)|>(?![=<])"
        },
        {
          "comment": "Kebab-minus +- (symmetric tolerance / range)",
          "name": "keyword.operator.arithmetic.comp",
          "match": "\\+-"
        },
        {
          "comment": "Arithmetic operators + - * /",
          "name": "keyword.operator.arithmetic.comp",
          "match": "[+\\-*/]"
        },
        {
          "comment": "Assignment =",
          "name": "keyword.operator.assignment.comp",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "comment": "Field access dot — not followed by a digit",
          "name": "punctuation.accessor.comp",
          "match": "\\.(?![0-9])"
        }
      ]
    },

    "type-names": {
      "patterns": [
        {
          "comment": "Commonly-used built-in type names",
          "name": "support.type.builtin.comp",
          "match": "\\b(text|num|bool|any|nil)\\b"
        }
      ]
    },

    "function-calls": {
      "patterns": [
        {
          "comment": "Qualified call module.function",
          "name": "entity.name.function.comp",
          "match": "[a-zA-Z_][\\w-]*\\.[a-zA-Z_][\\w.-]*(?=\\s*(\\(|\\{|\\[))"
        },
        {
          "comment": "Unqualified function call — identifier before ( { [",
          "name": "entity.name.function.comp",
          "match": "[a-zA-Z_][\\w-]*(?=\\s*(\\(|\\{|\\[))"
        }
      ]
    }
  }
}
